generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  ACTIVE
  COMPLETED
  FAILED
}

enum TransactionType {
  EXPENSE
  INCOME
}

enum TransactionCategory {
  SELF
  PARTNER
  SHARED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  points    Int      @default(100)
  createdAt DateTime @default(now())

  pairId String?
  pair   Pair?    @relation(fields: [pairId], references: [id], onDelete: SetNull)

  createdTasks  Task[] @relation("CreatedTasks")
  assignedTasks Task[] @relation("AssignedTasks")
  createdEvents Event[] @relation("CreatedEvents")
  createdTransactions Transaction[] @relation("CreatedTransactions")
}

model Pair {
  id        String   @id @default(uuid())
  joinCode  String   @unique
  createdAt DateTime @default(now())

  users User[]
  tasks Task[]
  events Event[]
  transactions Transaction[]
}

model Task {
  id           String     @id @default(uuid())
  title        String
  bank         Int
  status       TaskStatus @default(ACTIVE)
  assignedToId String
  createdById  String
  pairId       String
  dueDate      DateTime?
  createdAt    DateTime   @default(now())

  assignedTo User @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: Restrict)
  createdBy  User @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Restrict)
  pair       Pair @relation(fields: [pairId], references: [id], onDelete: Cascade)

  @@index([pairId, createdAt])
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  pairId      String
  createdById String
  createdAt   DateTime @default(now())

  pair      Pair @relation(fields: [pairId], references: [id], onDelete: Cascade)
  createdBy User @relation("CreatedEvents", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([pairId, date])
}

model Transaction {
  id          String              @id @default(uuid())
  title       String
  amount      Float
  type        TransactionType
  category    TransactionCategory
  createdById String
  pairId      String
  createdAt   DateTime            @default(now())

  createdBy User @relation("CreatedTransactions", fields: [createdById], references: [id], onDelete: Restrict)
  pair      Pair @relation(fields: [pairId], references: [id], onDelete: Cascade)

  @@index([pairId, createdAt])
}
